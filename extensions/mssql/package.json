{
    "name": "justybase-mssql",
    "displayName": "MSSQL Tools (justybase)",
    "description": "Optional Microsoft SQL Server support for Netezza SQL Tools (justybase)",
    "version": "3.16.7",
    "publisher": "justybase",
    "license": "Apache-2.0",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.103.2",
        "node": ">=22.0.0"
    },
    "categories": [
        "Programming Languages",
        "Data Science",
        "Other"
    ],
    "homepage": "https://github.com/justybase/justybase-vscode",
    "bugs": {
        "url": "https://github.com/justybase/justybase-vscode/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/justybase/justybase-vscode"
    },
    "keywords": [
        "SQL",
        "mssql",
        "sqlserver",
        "database"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "extensionDependencies": [
        "justybase.justybase-netezza"
    ],
    "scripts": {
        "build": "node esbuild.mssql.js --production",
        "build:dev": "node esbuild.mssql.js",
        "check-types": "node ../../node_modules/typescript/bin/tsc --project tsconfig.json --noEmit",
        "verify:runtime-deps": "node -e \"const fs = require('fs'); if (!fs.existsSync('node_modules/mssql')) { console.error('Missing mssql. Run npm install in extensions\\\\mssql before packaging.'); process.exit(1); }\"",
        "prepackage": "npm run verify:runtime-deps",
        "package": "node ../../node_modules/@vscode/vsce/vsce package"
    },
    "dependencies": {
        "mssql": "^11.0.1"
    },
    "devDependencies": {
        "@types/mssql": "^9.1.9"
    },
    "preview": true
}
