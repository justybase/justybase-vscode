{
    "name": "justybaselite-mysql",
    "displayName": "JustyBase MySQL Support",
    "description": "Optional MySQL Support for JustyBase Core",
    "version": "3.16.9",
    "publisher": "krzysztof-d",
    "license": "Apache-2.0",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.103.2",
        "node": ">=22.0.0"
    },
    "categories": [
        "Programming Languages",
        "Data Science",
        "Other"
    ],
    "homepage": "https://github.com/justybase/justybase-vscode",
    "bugs": {
        "url": "https://github.com/justybase/justybase-vscode/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/justybase/justybase-vscode"
    },
    "keywords": [
        "SQL",
        "mysql",
        "mariadb",
        "database"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "extensionDependencies": [
        "krzysztof-d.justybaselite-netezza"
    ],
    "scripts": {
        "vscode:prepublish": "npm run build && node ../../scripts/generate-third-party-notices.js .",
        "build": "node esbuild.mysql.js",
        "build:minified": "node esbuild.mysql.js --minify",
        "build:dev": "node esbuild.mysql.js",
        "check-types": "node ../../node_modules/typescript/bin/tsc --project tsconfig.json --noEmit",
        "verify:runtime-deps": "node -e \"const fs = require('fs'); if (!fs.existsSync('node_modules/mysql2')) { console.error('Missing mysql2. Run npm install in extensions\\\\mysql before packaging.'); process.exit(1); }\"",
        "prepackage": "npm run verify:runtime-deps",
        "package": "node ../../scripts/package-optional-vsix.js package"
    },
    "dependencies": {
        "mysql2": "^3.11.5"
    },
    "preview": true
}
