{
    "name": "justybaselite-oracle",
    "displayName": "JustyBase Oracle Support",
    "description": "Optional Oracle Support for JustyBase Core using node-oracledb thin mode",
    "version": "3.16.10",
    "publisher": "krzysztof-d",
    "license": "Apache-2.0",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.103.2",
        "node": ">=22.0.0"
    },
    "categories": [
        "Programming Languages",
        "Data Science",
        "Other"
    ],
    "homepage": "https://github.com/justybase/justybase-vscode",
    "bugs": {
        "url": "https://github.com/justybase/justybase-vscode/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/justybase/justybase-vscode"
    },
    "keywords": [
        "SQL",
        "oracle",
        "oracledb",
        "database"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "extensionDependencies": [
        "krzysztof-d.justybaselite-netezza"
    ],
    "scripts": {
        "vscode:prepublish": "npm run build && node ../../scripts/generate-third-party-notices.js .",
        "build": "node esbuild.oracle.js",
        "build:minified": "node esbuild.oracle.js --minify",
        "build:dev": "node esbuild.oracle.js",
        "check-types": "node ../../node_modules/typescript/bin/tsc --project tsconfig.json --noEmit",
        "verify:runtime-deps": "node -e \"const fs = require('fs'); if (!fs.existsSync('node_modules/oracledb')) { console.error('Missing oracledb. Run npm install in extensions\\\\oracle before packaging.'); process.exit(1); }\"",
        "prepackage": "npm run verify:runtime-deps",
        "package": "node ../../scripts/package-optional-vsix.js package"
    },
    "dependencies": {
        "oracledb": "^6.9.0"
    },
    "preview": true
}
